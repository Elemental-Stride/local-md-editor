{
  "name": "local-md-editor",
  "version": "0.0.1",
  "private": true,
  "description": "Local-first, privacy-focused, Notion-like Markdown editor for VS Code",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter ./shared --filter ./webview --filter ./extension run build",
    "dev": "pnpm -r --parallel --filter ./webview --filter ./extension run dev",
    "typecheck": "pnpm --filter ./shared run build && pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "lint": "oxlint",
    "format": "dprint fmt",
    "format:check": "dprint check"
  },
  "devDependencies": {
    "dprint": "^0.48.0",
    "oxlint": "^0.15.0",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dprint",
      "esbuild"
    ]
  }
}
