{
  "name": "@local-md-editor/webview",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node esbuild.config.mjs && pnpm build:css",
    "build:css": "tailwindcss -i ./src/styles.css -o ../extension/dist/webview/styles.css --minify",
    "dev": "concurrently \"node esbuild.config.mjs --watch\" \"pnpm build:css --watch\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf ../extension/dist/webview"
  },
  "dependencies": {
    "@local-md-editor/shared": "workspace:*",
    "mermaid": "^11.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/vscode-webview": "^1.57.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "esbuild": "^0.25.0",
    "happy-dom": "^20.9.0",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  }
}
